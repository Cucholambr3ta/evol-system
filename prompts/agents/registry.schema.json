{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evol-DD Agent Registry",
  "description": "Schema for agent registry with core and ephemeral agents",
  "type": "object",
  "required": ["$schema", "version", "generated", "agents"],
  "properties": {
    "$schema": {
      "type": "string",
      "pattern": "registry\\.schema\\.json$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generated": {
      "type": "string",
      "format": "date-time"
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "category", "ephemeral", "retired"],
        "properties": {
          "id": {
            "oneOf": [
              {"type": "integer", "minimum": 1},
              {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}
            ],
            "description": "Numeric ID for core, kebab-case name for ephemeral"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Agent name"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Brief description of agent purpose"
          },
          "category": {
            "type": "string",
            "enum": ["core", "ephemeral"],
            "description": "Agent category"
          },
          "file": {
            "type": "string",
            "pattern": "^(core|ephemeral)/[a-z0-9-]+\\.md$",
            "description": "Path to agent prompt file (core agents)"
          },
          "triggers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^/evol\\s"
            },
            "description": "CLI trigger patterns (core agents)"
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Associated skill identifiers"
          },
          "ephemeral": {
            "type": "boolean",
            "description": "True if agent is temporary and can be retired"
          },
          "retired": {
            "description": "If boolean false or null: not retired. If true or timestamp: retired with timestamp."
          },
          "retired_at": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "ISO timestamp when retired. Required if retired is true/timestamp, must be null/absent if not retired."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp (ephemeral agents)"
          },
          "created_for_task": {
            "type": "string",
            "description": "Task description for ephemeral agents"
          },
          "expires_after_days": {
            "type": "integer",
            "minimum": 1,
            "description": "TTL in days for ephemeral agents"
          },
          "sessions_used": {
            "type": "integer",
            "minimum": 0,
            "description": "Session count for ephemeral agents"
          },
          "recalled": {
            "type": "boolean",
            "description": "Whether ephemeral agent was recalled"
          },
          "recalled_at": {
            "type": ["string", "null"],
            "format": "date-time"
          }
        },
        "required": ["id", "name", "description", "category", "ephemeral"],
        "if": {
          "properties": {"category": {"const": "core"}},
          "required": ["category"]
        },
        "then": {
          "properties": {
            "file": {"type": "string", "pattern": "^(core|ephemeral)/[a-z0-9-]+\\.md$"},
            "triggers": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "pattern": "^/evol\\s"}
            }
          },
          "required": ["file", "triggers"]
        }
      }
    }
  }
}