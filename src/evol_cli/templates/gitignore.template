# .gitignore — generated by evol-init.sh
# Destination projects may version installed Evol-DD source assets when a profile
# copies them. Ignore only runtime state, generated IDE outputs, caches, build
# artifacts, local indexes, and secrets.

# Evol-DD runtime state (never versionable)
.evol/
dialog/
tool_result/
memory/raw/
.evol-mcp-exclude

# Local indexes and machine-specific memory
.gitnexus/
mempalace.yaml
entities.json

# IDE/adaptor generated outputs
.claude/
.opencode/
.cursor/
.windsurf/
.agents/
.antigravity/
.codex/
.github/prompts/

# Build and package artifacts
dist/
build/
*.egg-info/
*.whl

# Python caches
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage
.mypy_cache/
.ruff_cache/

# Virtual environments and dependencies
.venv/
venv/
env/
node_modules/

# Secrets and credentials
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json

# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.swo

# Project artifacts that should remain trackable when generated by Evol-DD.
!memoria.md
!lecciones.md
!AGENT_MEMORY.md
!memory/
!evol.profile.yml
!evol.config.yml
!CLAUDE.md
!AGENTS.md
!docs/
!.agent/
!.agent/hooks/
!.agent/hooks/scripts/
!.agent/workflows/
!.github/
!.github/workflows/
