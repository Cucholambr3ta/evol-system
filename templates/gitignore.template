# .gitignore — generated by evol-init.sh
# Destination projects may version installed Evol-DD source assets when a profile
# copies them. Ignore only runtime state, generated IDE outputs, caches, build
# artifacts, local indexes, and secrets.

# Evol-DD runtime state (never versionable)
.evol/
dialog/
tool_result/
memory/raw/
.evol-mcp-exclude

# Local indexes and machine-specific memory
.gitnexus/
entities.json

# IDE/adaptor generated outputs
.claude/
.opencode/
.cursor/
.windsurf/
.agents/
.antigravity/
.codex/
.github/prompts/

# Build and package artifacts
dist/
build/
*.egg-info/
*.whl

# Python caches
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage
.mypy_cache/
.ruff_cache/

# Virtual environments and dependencies
.venv/
venv/
env/
node_modules/

# Secrets and credentials
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json

# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.swo

# Evol-DD Framework Artifacts (Strict Local Mode)
# Todos los artefactos generados por el framework para que no dejen rastro
.evol/
.agent/
acuerdos/
memory/
memoria.md
lecciones.md
WORKING-CONTEXT.md
AGENT_MEMORY.md
evol.profile.yml
evol.config.yml
CLAUDE.md
AGENTS.md
agent.yaml
scripts/evol-*
docs/features/
docs/domain/
docs/privacy/
api/openapi/fragments/
