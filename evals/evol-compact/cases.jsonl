{"id":"compact-001","description":"SKILL.md has frontmatter with name, description, category, trigger","assertions":[{"type":"structural","check":"frontmatter","path":"skills/evol-compact/SKILL.md","required":["name","description","category","trigger"]}]}
{"id":"compact-002","description":"Defines compression levels","assertions":[{"type":"output_match","check":"levels","path":"skills/evol-compact/SKILL.md","pattern":"light.*medium.*aggressive"}]}
