{"id":"compact-004","description":"References itself in Reference section","assertions":[{"type":"output_match","check":"reference","path":"skills/evol-compact/SKILL.md","pattern":"skills/evol-compact/SKILL.md"}]}
{"id":"compact-005","description":"Has Commands section with /compact","assertions":[{"type":"structural","check":"section","path":"skills/evol-compact/SKILL.md","required":["Commands"]}]}